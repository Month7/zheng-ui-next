{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "strict": false,
    "moduleResolution": "node",
    "allowJs": true,
    "jsx": "preserve",
    "paths": {
      "@packages/*": ["./packages/*"],
    }
  },
  "include": ["packages/**/*.vue", "packages"],
  "exclude": [
    "stories",
    "output",
    "node_modules"
  ],
}